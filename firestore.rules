rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Social discovery
      allow create: if isOwner(userId) 
        && incoming().uid == userId
        && incoming().createdAt == request.time.toMillis();
      allow update: if isOwner(userId)
        && incoming().uid == userId
        && incoming().email == existing().email;
    }

    // 2. Posts Collection
    match /posts/{postId} {
      allow read: if isSignedIn(); // Simplified for MVP (friends-only logic would need a follow/friend collection)
      
      function isValidPost(data) {
        return data.authorId is string 
          && data.content is string 
          && data.content.size() <= 5000
          && data.privacy in ['public', 'friends'];
      }

      allow create: if isSignedIn() 
        && isOwner(incoming().authorId)
        && isValidPost(incoming());

      allow update: if isSignedIn() && (
        // Case 1: Author updates content
        (isOwner(existing().authorId) && isValidPost(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'mediaURL', 'privacy']))
        || 
        // Case 2: Any user adds/removes reaction
        (incoming().diff(existing()).affectedKeys().hasOnly(['reactions']))
      );

      allow delete: if isSignedIn() && isOwner(existing().authorId);
    }

    // 3. Messages Collection
    match /messages/{messageId} {
      allow read: if isSignedIn() && (isOwner(resource.data.senderId) || isOwner(resource.data.receiverId));
      allow create: if isSignedIn() && isOwner(incoming().senderId);
      allow update: if isSignedIn() && isOwner(existing().receiverId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }
  }
}
