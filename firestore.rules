rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid is string && data.uid == userId
          && data.username is string
          && data.email is string;
      }

      allow get, list: if isSignedIn();
      
      allow create: if isOwner(userId) 
        && isValidUser(incoming());
        
      allow update: if isOwner(userId)
        && isValidUser(incoming())
        && incoming().email == existing().email;
    }

    match /test/connection {
      allow get: if true;
    }

    // 2. Posts Collection
    match /posts/{postId} {
      allow read: if isSignedIn() && (
        resource.data.privacy == 'public' || isOwner(resource.data.authorId)
      );
      
      function isValidPost(data) {
        return data.authorId is string && data.authorId.size() <= 128
          && data.content is string && data.content.size() <= 5000
          && data.privacy in ['public', 'friends']
          && data.reactions is map
          && data.reactions.heart is list && data.reactions.heart.size() <= 1000
          && data.reactions.like is list && data.reactions.like.size() <= 1000
          && data.reactions.flag is list && data.reactions.flag.size() <= 1000;
      }

      allow create: if isSignedIn() 
        && isValidId(postId)
        && isOwner(incoming().authorId)
        && isValidPost(incoming());

      allow update: if isSignedIn() && isValidId(postId) && (
        (isOwner(existing().authorId) && isValidPost(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'mediaURL', 'privacy']))
        || 
        (incoming().diff(existing()).affectedKeys().hasOnly(['reactions']) && isValidPost(incoming()))
      );

      allow delete: if isSignedIn() && isValidId(postId) && isOwner(existing().authorId);
    }

    // 3. Messages Collection
    match /messages/{messageId} {
      allow read: if isSignedIn() && (isOwner(resource.data.senderId) || isOwner(resource.data.receiverId));
      allow create: if isSignedIn() && isOwner(incoming().senderId);
      allow update: if isSignedIn() && isOwner(existing().receiverId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }
  }
}
